# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.

# ---- Clerk (auth) ----
# Get these from https://dashboard.clerk.com > your app > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Where Clerk's pre-built sign-in / sign-up components are mounted.
# These match the route files under src/app/sign-in and src/app/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Where to redirect after sign-in / sign-up when no other destination was set.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
# Signing secret for the Clerk → /api/clerk-webhook endpoint (user
# lifecycle events). Get this from Clerk dashboard → Configure →
# Webhooks → your endpoint → Signing Secret. Starts with "whsec_".
# Only needed on environments where Clerk actually calls the webhook
# (Production).
CLERK_WEBHOOK_SIGNING_SECRET=

# ---- Supabase (database) ----
# Get these from https://supabase.com/dashboard > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key has full DB access. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI (coaching model) ----
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---- Cron (abandonment sweep) ----
# Shared secret between Vercel Cron and /api/cron/sweep-stale-sessions.
# Vercel auto-populates this when you add a cron in vercel.json, and
# auto-sends it as `Authorization: Bearer <CRON_SECRET>` on scheduled
# invocations. Only needs to be set manually for local dev or to
# hit the endpoint via curl.
CRON_SECRET=

# ---- Sentry (error tracking) ----
# Get this from https://sentry.io > your project > Settings > Client Keys (DSN).
# Leave blank in local dev to keep Sentry inert (no events sent).
NEXT_PUBLIC_SENTRY_DSN=
# Optional — only needed on CI / Vercel if you want source-map uploads.
# Without these the Sentry webpack plugin silently skips the upload step.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Flip to 1 in Vercel env to enable /api/sentry-test for a smoke test,
# then set back to empty. 404 when unset. See src/app/api/sentry-test.
ENABLE_SENTRY_TEST_ROUTE=
