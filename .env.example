# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.

# ---- Clerk (auth) ----
# Get these from https://dashboard.clerk.com > your app > API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Where Clerk's pre-built sign-in / sign-up components are mounted.
# These match the route files under src/app/sign-in and src/app/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Where to redirect after sign-in / sign-up when no other destination was set.
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ---- Supabase (database) ----
# Get these from https://supabase.com/dashboard > your project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key has full DB access. Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI (coaching model) ----
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ---- Sentry (error tracking) ----
# Get this from https://sentry.io > your project > Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
